# API keys
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Encryption key (minimaal 32 tekens)
MASTER_KEY=replace-with-strong-random-key-min-32-chars

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=blogbot
MYSQL_CONNECT_TIMEOUT_SECONDS=5
MYSQL_CONNECT_RETRIES=5
MYSQL_CONNECT_RETRY_DELAY_SECONDS=1.5

# Offline auth fallback (alleen gebruikt als MySQL niet bereikbaar is)
OFFLINE_AUTH_ENABLED=true
OFFLINE_AUTH_DB_PATH=offline_auth.db
OFFLINE_AUTH_USERNAME=offline_dev
OFFLINE_AUTH_PASSWORD=development
OFFLINE_AUTH_REGENERATE_ON_START=true

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_URL=http://localhost:8000

# Password reset
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# SMTP mail
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@example.com
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# Optional model overrides
OPENAI_TEXT_MODEL=gpt-4o
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_SIZE=2K

# Comma-separated list of admin account emails
ADMIN_EMAILS=admin@example.com

APP_PUBLIC_URL=http://localhost:8000
# API keys
OPENAI_API_KEY=your-openai-api-key

# Vertex AI auth (service account JSON)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

# Optional legacy key (not used for Vertex image calls)
GEMINI_API_KEY=

# Encryption key (minimaal 32 tekens)
MASTER_KEY=replace-with-strong-random-key-min-32-chars

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=blogbot

# App
APP_HOST=0.0.0.0
APP_PORT=8000
STRICT_VERTEX_STARTUP_CHECK=false

# Optional model overrides
OPENAI_TEXT_MODEL=gpt-4o
IMAGEN_MODEL=imagen-3.0-generate-002
IMAGEN_EDIT_MODEL=imagen-3.0-capability-001
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation

# Comma-separated list of admin account emails
ADMIN_EMAILS=admin@example.com
